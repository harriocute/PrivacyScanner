<?xml version="1.0" encoding="utf-8"?>
<!-- Privacy Scanner: No network communication allowed.
     This config explicitly blocks all cleartext traffic and external connections.
     All analysis is done 100% on-device. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
