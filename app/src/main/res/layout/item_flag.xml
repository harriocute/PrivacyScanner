<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="6dp">

    <TextView
        android:id="@+id/tv_flag_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/risk_high"
        android:textSize="13sp"
        android:textStyle="bold"
        tools:text="⚠ Location + Microphone Combo" />

    <TextView
        android:id="@+id/tv_flag_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="12sp"
        tools:text="Accessing both location and microphone simultaneously is a common spyware pattern." />

</LinearLayout>
